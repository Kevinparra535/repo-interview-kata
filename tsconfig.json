{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "module": "ESNext",
    "ignoreDeprecations": "5.0",
    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@/*": ["./*", "./src/*"],
      "@src/*": ["./src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
